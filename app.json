{
  "name": "sami",
  "slug": "sami",
  "scheme": "sami",
  "version": "1.0.0",
  "orientation": "portrait",
  "userInterfaceStyle": "automatic",
  "icon": "./assets/icon.png",
  "updates": {
    "fallbackToCacheTimeout": 0
  },
  "newArchEnabled": true,
  "jsEngine": "hermes",
  "assetBundlePatterns": [
    "**/*"
  ],
  "android": {
    "icon": "./assets/icon.png",
    "package": "com.sami",
    "adaptiveIcon": {
      "foregroundImage": "./assets/icon.png",
      "backgroundImage": "./assets/images/app-icon-android-adaptive-background.png"
    },
    "allowBackup": false,
    "edgeToEdgeEnabled": true
  },
  "ios": {
    "icon": "./assets/icon.png",
    "supportsTablet": true,
    "bundleIdentifier": "com.sami",
    "infoPlist": {
      "LSApplicationQueriesSchemes": [
        "instagram", "tiktok", "twitter", "fb", "snapchat", "pinterest",
        "linkedin", "tumblr", "bereal", "barcelona",
        "youtube", "twitch", "nflx", "hulu", "disneyplus", "primevideo", "max", "videos",
        "whatsapp", "tg", "discord", "fb-messenger", "sgnl", "slack",
        "roblox", "minecraft", "clashofclans", "king-candycrushsaga", "chess",
        "amazon", "ebay", "shein", "etsy",
        "spotify", "music", "soundcloud",
        "reddit", "applenews", "flipboard", "medium",
        "tinder", "bumble", "hinge",
        "x-web-search", "googlechrome",
        "doordash", "ubereats"
      ]
    }
  },
  "web": {
    "favicon": "./assets/icon.png",
    "bundler": "metro"
  },
  "plugins": [
    "expo-localization",
    "expo-font",
    [
      "expo-splash-screen",
      {
        "image": "./assets/images/app-icon-android-adaptive-foreground.png",
        "imageWidth": 300,
        "resizeMode": "contain",
        "backgroundColor": "#191015"
      }
    ],
    [
      "react-native-edge-to-edge",
      {
        "android": {
          "parentTheme": "Light",
          "enforceNavigationBarContrast": false
        }
      }
    ],
    "expo-build-properties"
  ],
  "experiments": {
    "tsconfigPaths": true
  },
  "extra": {
    "ignite": {
      "version": "11.5.0"
    }
  }
}